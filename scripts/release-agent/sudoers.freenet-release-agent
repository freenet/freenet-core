# Allow the release-agent to invoke the update script as root.
#
# The trailing `*` matches any single non-whitespace argument (sudoers glob
# semantics) — that's the `vX.Y.Z` value passed by the agent via
# `--target-version`. The agent verifies that the version matches GitHub's
# `latest` release before invoking, so the value here is constrained even
# though sudoers itself doesn't validate it.
#
# Relies on the default `secure_path` to prevent PATH-based shenanigans.
# The `gateway-auto-update.sh` script MUST be owned by root and NOT
# writable by `freenet-update`; the install script verifies this.
#
# Install path: /etc/sudoers.d/freenet-release-agent (mode 0440, owner root:root).
# Validate with: visudo -c -f /etc/sudoers.d/freenet-release-agent
freenet-update ALL=(root) NOPASSWD: /usr/local/bin/gateway-auto-update.sh --force --target-version *
