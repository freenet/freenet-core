[Unit]
Description=Freenet release agent (HTTP trigger for gateway updates)
Documentation=https://github.com/freenet/freenet-core/issues/4073
After=network-online.target
Wants=network-online.target

[Service]
Type=exec
User=freenet-update
Group=freenet-update
ExecStart=/usr/local/bin/freenet-release-agent --config /etc/freenet-release-agent/config.toml
Restart=on-failure
RestartSec=5s

# `NoNewPrivileges` must remain *false*: the agent execs `sudo` to invoke
# `gateway-auto-update.sh`. The narrow sudoers entry in
# /etc/sudoers.d/freenet-release-agent is the privilege boundary.
NoNewPrivileges=false

ProtectSystem=strict
ProtectHome=true
ReadWritePaths=/var/log/freenet-release-agent
PrivateTmp=true
PrivateDevices=true
ProtectKernelTunables=true
ProtectKernelModules=true
ProtectControlGroups=true
RestrictRealtime=true
LockPersonality=true
RestrictNamespaces=true
RestrictSUIDSGID=false
SystemCallArchitectures=native

StandardOutput=journal
StandardError=journal

[Install]
WantedBy=multi-user.target
